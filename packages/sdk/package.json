{
  "name": "stellaragent-sdk",
  "version": "0.1.0",
  "description": "Autonomous payments for AI agents on Stellar",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --watch --format cjs,esm --dts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^13.1.0"
  },
  "devDependencies": {
    "tsup": "^8.2.4",
    "typescript": "^5.6.3",
    "@types/node": "^22.10.2"
  }
}
