# StellarAgent Environment Variables

# Database (Required - use connection pooling for serverless)
DATABASE_URL=postgresql://user:password@host:port/database?pgbouncer=true

# Stellar Network Configuration
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# Platform Wallets (Required)
PLATFORM_PUBLIC_KEY=G...
PLATFORM_SECRET_KEY=S...
SPONSOR_SECRET_KEY=S...
DEMO_AGENT_SECRET_KEY=S...

# Fee Configuration
FEE_BPS=30

# Security (Required - change in production)
API_KEY_PEPPER=your-secure-random-pepper-min-32-chars
INDEXER_SECRET=your-secure-indexer-secret

# Public URL (Required for Vercel)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app
NEXT_PUBLIC_SALES_EMAIL=sales@yourdomain.com

# Optional: Redis/Upstash for distributed rate limiting (Recommended for production)
UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Optional: OpenAI for LLM features
OPENAI_API_KEY=sk-...
