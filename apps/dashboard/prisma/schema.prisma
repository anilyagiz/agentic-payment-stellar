generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionStatus {
  pending
  submitted
  confirmed
  failed
}

enum CustomerStatus {
  lead
  trial
  active
  churned
}

model Agent {
  id           String        @id @default(cuid())
  name         String
  publicKey    String        @unique
  apiKeyPrefix  String        @unique
  apiKeyHash    String
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  transactions Transaction[]
  customer     Customer?
}

model Customer {
  id               String         @id @default(cuid())
  name             String
  email            String         @unique
  company          String?
  plan             String         @default("Starter")
  monthlyVolumeUsd String         @default("0")
  status           CustomerStatus  @default(lead)
  source           String         @default("pricing")
  walletPublicKey  String?        @unique
  notes            String?
  lastContactAt    DateTime?
  agentId          String?        @unique
  agent            Agent?         @relation(fields: [agentId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Transaction {
  id             String            @id @default(cuid())
  agentId        String
  agent          Agent             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  txHash         String            @unique
  sourceAccount   String
  destination    String
  amount         String
  fee            String
  memo           String?
  network        String
  status         TransactionStatus @default(submitted)
  operationCount Int               @default(0)
  submittedAt    DateTime          @default(now())
  confirmedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model PlatformEarning {
  id         String   @id @default(cuid())
  txHash     String   @unique
  amount     String
  network    String
  createdAt  DateTime @default(now())
}

model IndexCursor {
  id        String   @id @default(cuid())
  name      String   @unique
  cursor    String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}
